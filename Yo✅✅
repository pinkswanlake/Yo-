#include "life.h"

void init_game(t_game *game, int width, int height, int iterations)
{
	int y;
	int x;

	game->width = width;
	game->height = height;
	game->iterations = iterations;

	game->map = malloc(game->height * sizeof(char *));
	y = 0;
	while (y < game->height)
	{
		game->map[y] = malloc(game->width * sizeof(char));
		x = 0;
		while (x < game->width)
		{
			game->map[y][x] = ' ';
			x = x + 1;
		}
		y = y + 1;
	}
}

void free_map(t_game *game)
{
	int y;

	if (game->map == NULL)
		return ;
	y = 0;
	while (y < game->height)
	{
		if (game->map[y] != NULL)
			free(game->map[y]);
		y = y + 1;
	}
	free(game->map);
}

void fill_map(t_game *game)
{
	char	buffer;
	int		x;
	int		y;
	int		drawing;

	x = 0;
	y = 0;
	drawing = 0;
	while (read(STDIN_FILENO, &buffer, 1) == 1)
	{
		if (buffer == 'w')
		{
			if (y > 0)
				y = y - 1;
		}
		else if (buffer == 'a')
		{
			if (x > 0)
				x = x - 1;
		}
		else if (buffer == 's')
		{
			if (y < game->height - 1)
				y = y + 1;
		}
		else if (buffer == 'd')
		{
			if (x < game->width - 1)
				x = x + 1;
		}
		else if (buffer == 'x')
		{
			if (drawing == 0)
				drawing = 1;
			else
				drawing = 0;
		}
		if (drawing == 1)
			game->map[y][x] = 'O';
	}
}

int count_neighbors(t_game *game, int y, int x)
{
	int	count;
	int	dy;
	int	dx;
	int	ny;
	int	nx;

	count = 0;
	dy = -1;
	while (dy <= 1)
	{
		dx = -1;
		while (dx <= 1)
		{
			if (dy != 0 || dx != 0)
			{
				ny = y + dy;
				nx = x + dx;
				if (ny >= 0 && ny < game->height && nx >= 0 && nx < game->width)
				{
					if (game->map[ny][nx] == 'O')
						count = count + 1;
				}
			}
			dx = dx + 1;
		}
		dy = dy + 1;
	}
	return (count);
}

void play_game(t_game *game)
{
	char	**new_map;
	int		y;
	int		x;
	int		neighbors;

	new_map = malloc(game->height * sizeof(char *));
	y = 0;
	while (y < game->height)
	{
		new_map[y] = malloc(game->width * sizeof(char));
		y = y + 1;
	}

	y = 0;
	while (y < game->height)
	{
		x = 0;
		while (x < game->width)
		{
			neighbors = count_neighbors(game, y, x);
			if (game->map[y][x] == 'O')
			{
				if (neighbors == 2 || neighbors == 3)
					new_map[y][x] = 'O';
				else
					new_map[y][x] = ' ';
			}
			else
			{
				if (neighbors == 3)
					new_map[y][x] = 'O';
				else
					new_map[y][x] = ' ';
			}
			x = x + 1;
		}
		y = y + 1;
	}

	free_map(game);
	game->map = new_map;
}

void print_map(t_game *game)
{
	int	y;
	int	x;

	y = 0;
	while (y < game->height)
	{
		x = 0;
		while (x < game->width)
		{
			putchar(game->map[y][x]);
			x = x + 1;
		}
		putchar('\n');
		y = y + 1;
	}
}

int main(int argc, char **argv)
{
	t_game	game;
	int		i;

	if (argc != 4)
		return (1);

	init_game(&game, atoi(argv[1]), atoi(argv[2]), atoi(argv[3]));
	fill_map(&game);

	i = 0;
	while (i < game.iterations)
	{
		play_game(&game);
		i = i + 1;
	}

	print_map(&game);
	free_map(&game);
	return (0);
}
